<!DOCTYPE html>
<html>
<head>
  <title>ShopLite Store</title>

  <style>
    body {
      font-family: Arial, sans-serif;
      background: #f4f4f4;
      padding: 20px;
    }

    h1 {
      text-align: center;
    }

    #products {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 20px;
      margin-top: 20px;
    }

    .product {
      background: white;
      padding: 15px;
      border-radius: 10px;
      box-shadow: 0 2px 5px rgba(0,0,0,0.1);
      text-align: center;
    }

    button {
      padding: 10px;
      cursor: pointer;
    }

    .cart {
      text-align: center;
      margin-top: 20px;
      font-size: 22px;
      font-weight: bold;
    }
  </style>
</head>

<body>

<h1>🛒 ShopLite Store</h1>

<div id="products"></div>

<div class="cart">
  Cart Items: <span id="count">0</span>
</div>

<script>
const products = [
  {
    id: 1,
    name: "T-Shirt",
    price: 500
  },
  {
    id: 2,
    name: "Sneakers",
    price: 2000
  },
  {
    id: 3,
    name: "Cap",
    price: 300
  }
];

let cart = [];

function renderProducts() {
  const container = document.getElementById("products");

  products.forEach(product => {
    container.innerHTML += `
      <div class="product">
        <h3>${product.name}</h3>
        <p>KSh ${product.price}</p>
        <button onclick="addToCart(${product.id})">
          Add to Cart
        </button>
      </div>
    `;
  });
}

function addToCart(id) {
  const item = products.find(product => product.id === id);

  cart.push(item);

  document.getElementById("count").innerText = cart.length;
}

renderProducts();
</script>

</body>
</html>